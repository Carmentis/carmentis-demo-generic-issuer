{{!-- Liste des clés de signature --}}
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-0 fw-bold">Clés de signature</h2>
    <p class="text-muted small mb-0 mt-1">Gérez les clés utilisées pour émettre des SD-JWT-VC.</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin/keys/import" class="btn btn-outline-primary">
      <i class="bi bi-upload me-1"></i> Importer
    </a>
    <a href="/admin/keys/new" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i> Nouvelle clé
    </a>
  </div>
</div>

{{#if keys.length}}
<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Nom</th>
          <th>Identifier</th>
          <th>Algo</th>
          <th>Clés d'API</th>
          <th>Credentials</th>
          <th>Créée le</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each keys}}
        <tr>
          <td class="fw-semibold">{{this.name}}</td>
          <td><code class="key-badge">{{this.identifier}}</code></td>
          <td><span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">{{this.algorithm}}</span></td>
          <td>
            {{#if this.activeApiKeyCount}}
            <span class="badge bg-success-subtle text-success border border-success-subtle">
              <i class="bi bi-check-circle-fill me-1"></i>{{this.activeApiKeyCount}} active(s)
            </span>
            {{else}}
            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
              <i class="bi bi-exclamation-circle me-1"></i>Aucune
            </span>
            {{/if}}
          </td>
          <td class="text-muted small">{{this.statusListCurrent}} émis</td>
          <td class="text-muted small">{{this.createdAt}}</td>
          <td class="text-end">
            <a href="/admin/keys/{{this.id}}" class="btn btn-sm btn-outline-primary me-1">
              <i class="bi bi-eye me-1"></i>Détails
            </a>
            <form action="/admin/keys/{{this.id}}/delete" method="POST" class="d-inline"
                  onsubmit="return confirm('Supprimer la clé «\u202F{{this.name}}\u202F» ? Cette action est irréversible.')">
              <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash3"></i>
              </button>
            </form>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
{{else}}
<div class="card shadow-sm">
  <div class="card-body text-center py-5">
    <div class="mb-3" style="font-size:3rem; opacity:.3;"><i class="bi bi-key-fill"></i></div>
    <h5 class="text-muted">Aucune clé de signature</h5>
    <p class="text-muted small">Créez une première clé pour commencer à émettre des credentials.</p>
    <a href="/admin/keys/new" class="btn btn-primary mt-1">
      <i class="bi bi-plus-lg me-1"></i> Créer une clé
    </a>
  </div>
</div>
{{/if}}
