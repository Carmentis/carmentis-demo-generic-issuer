{{!-- Formulaire de création d'une clé d'API --}}
<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="d-flex align-items-center mb-4">
      <a href="/admin/keys/{{key.id}}" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left me-1"></i>Retour
      </a>
      <h2 class="mb-0 fw-bold">Nouvelle clé d'API</h2>
    </div>

    <div class="alert alert-info d-flex gap-2 align-items-start mb-4 py-3">
      <i class="bi bi-info-circle-fill flex-shrink-0 mt-1"></i>
      <div class="small">
        Associée à la clé <strong>{{key.name}}</strong> (<code>{{key.identifier}}</code>).
        Elle autorise l'appel à <code>POST /api/{{key.identifier}}/issue</code>.
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-4">
        <form method="POST" action="/admin/keys/{{key.id}}/api-keys">
          <div class="mb-4">
            <label for="label" class="form-label fw-semibold">Label <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="label" name="label"
              placeholder="ex : Pipeline CI/CD production"
              required autofocus>
            <div class="form-text">Usage interne — aide à identifier la clé plus tard.</div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-gear me-1"></i>Générer la clé
            </button>
            <a href="/admin/keys/{{key.id}}" class="btn btn-outline-secondary">Annuler</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
